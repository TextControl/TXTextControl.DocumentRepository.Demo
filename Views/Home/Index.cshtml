@model tx_repo_demo.Models.DocumentSearchViewModel
@{
    ViewData["Title"] = "Document Repository";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="display-5">Document Repository</h1>
        <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#createDocumentModal">
            <i class="bi bi-plus-circle"></i> Create New Document
        </button>
    </div>

    <!-- Search Bar -->
    <div class="card mb-4">
        <div class="card-body">
            <form method="get" asp-action="Index" asp-controller="Home" id="searchForm">
                <div class="row g-3">
                    <div class="col-md-6">
                        <div class="input-group">
                            <span class="input-group-text"><i class="bi bi-search"></i></span>
                            <input type="text" 
                                   class="form-control" 
                                   name="q" 
                                   id="searchQuery"
                                   value="@Model.SearchQuery" 
                                   placeholder="Search documents by title or subject...">
                        </div>
                    </div>
                    <div class="col-md-2">
                        <input type="text" 
                               class="form-control" 
                               name="tags" 
                               value="@Model.SearchTags"
                               placeholder="Tags (comma-separated)">
                    </div>
                    <div class="col-md-2">
                        <input type="text" 
                               class="form-control" 
                               name="author" 
                               value="@Model.SearchAuthor"
                               placeholder="Author">
                    </div>
                    <div class="col-md-2">
                        <select class="form-select" name="status">
                            <option value="">All Status</option>
                            <option value="active" selected="@(Model.SearchStatus == "active")">✓ Active</option>
                            <option value="draft" selected="@(Model.SearchStatus == "draft")">📝 Draft</option>
                            <option value="archived" selected="@(Model.SearchStatus == "archived")">📦 Archived</option>
                        </select>
                    </div>
                </div>
                <div class="row mt-2">
                    <div class="col-12">
                        <button type="submit" class="btn btn-primary btn-sm">
                            <i class="bi bi-search"></i> Search
                        </button>
                        @if (Model.IsSearchActive)
                        {
                            <a href="@Url.Action("Index", "Home")" class="btn btn-secondary btn-sm">
                                <i class="bi bi-x-circle"></i> Clear Search
                            </a>
                            <span class="ms-3 text-muted">
                                <i class="bi bi-info-circle"></i> 
                                Found <strong>@Model.TotalResults</strong> document(s)
                                @if (Model.HasMore)
                                {
                                    <span class="text-warning">(showing first @Model.DisplayedResults)</span>
                                }
                            </span>
                        }
                    </div>
                </div>
            </form>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">
            <i class="bi bi-check-circle"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show">
            <i class="bi bi-exclamation-triangle"></i> @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (Model == null || !Model.Documents.Any())
    {
        <div class="alert alert-info">
            <i class="bi bi-info-circle"></i> 
            @if (Model?.IsSearchActive == true)
            {
                <span>No documents found matching your search criteria.</span>
            }
            else
            {
                <span>No documents found in the repository.</span>
            }
        </div>
    }
    else
    {
        <!-- Search Results Summary -->
        @if (Model.IsSearchActive)
        {
            <div class="alert alert-success mb-3">
                <i class="bi bi-check-circle"></i> 
                <strong>Search Results:</strong> Showing @Model.DisplayedResults of @Model.TotalResults document(s)
                @if (Model.HasMore)
                {
                    <span class="text-warning ms-2">
                        <i class="bi bi-exclamation-triangle"></i> More results available - refine your search for better results
                    </span>
                }
            </div>
        }

        <div class="table-responsive dashboard-card">
            <table class="table table-hover dashboard-table">
                <thead class="table-dark">
                    <tr>
                        <th width="30"></th>
                        <th>Title</th>
                        <th>Subject</th>
                        <th>Created By</th>
                        <th>Created</th>
                        <th>Updated</th>
                        <th>Version</th>
                        <th>Status</th>
                        <th>Tags</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var doc in Model.Documents)
                    {
                        var collapseId = $"versions-{doc.DocumentId}";
                        <tr class="document-row" data-collapse-target="#@collapseId" style="cursor: pointer;">
                            <td>
                                <i class="bi bi-chevron-right expand-icon"></i>
                            </td>
                            <td>
                                <strong>@doc.Title</strong>
                            </td>
                            <td>@doc.Subject</td>
                            <td>@doc.CreatedBy</td>
                            <td>@doc.CreatedAtUtc.ToLocalTime().ToString("MM/dd/yyyy")</td>
                            <td>@doc.UpdatedAtUtc.ToLocalTime().ToString("MM/dd/yyyy")</td>
                            <td>
                                <span class="badge bg-secondary">@doc.CurrentVersion</span>
                            </td>
                            <td class="status-cell">
                                <div class="dropdown">
                                    <button class="btn btn-sm dropdown-toggle status-badge @(doc.Status == "active" ? "btn-success" : doc.Status == "draft" ? "btn-info" : "btn-warning")" 
                                            type="button" 
                                            id="statusDropdown-@doc.DocumentId" 
                                            data-bs-toggle="dropdown" 
                                            aria-expanded="false">
                                        <i class="bi bi-circle-fill"></i> @doc.Status
                                    </button>
                                    <ul class="dropdown-menu" aria-labelledby="statusDropdown-@doc.DocumentId">
                                        <li>
                                            <a class="dropdown-item @(doc.Status == "active" ? "active" : "")" 
                                               href="#" 
                                               data-document-id="@doc.DocumentId"
                                               data-status="active">
                                                <i class="bi bi-check-circle text-success"></i> Active
                                            </a>
                                        </li>
                                        <li>
                                            <a class="dropdown-item @(doc.Status == "archived" ? "active" : "")" 
                                               href="#" 
                                               data-document-id="@doc.DocumentId"
                                               data-status="archived">
                                                <i class="bi bi-archive text-warning"></i> Archived
                                            </a>
                                        </li>
                                        <li>
                                            <a class="dropdown-item @(doc.Status == "draft" ? "active" : "")" 
                                               href="#" 
                                               data-document-id="@doc.DocumentId"
                                               data-status="draft">
                                                <i class="bi bi-file-text text-info"></i> Draft
                                            </a>
                                        </li>
                                    </ul>
                                </div>
                            </td>
                            <td>
                                @if (doc.Tags.Any())
                                {
                                    @foreach (var tag in doc.Tags)
                                    {
                                        <span class="badge bg-info text-dark me-1">@tag</span>
                                    }
                                }
                                else
                                {
                                    <span class="text-muted">-</span>
                                }
                            </td>
                            <td class="row-action-cell">
                                <button type="button"
                                        class="btn btn-outline-danger btn-sm"
                                        onclick="openDeleteModal('@doc.DocumentId', '@doc.Title'.trim() || 'this document'); event.stopPropagation();"
                                        title="Delete this document">
                                    <i class="bi bi-trash"></i> Delete
                                </button>
                            </td>
                        </tr>
                        <tr class="collapse" id="@collapseId">
                            <td colspan="9" class="p-0">
                                <div class="version-panel p-3">
                                    <h6 class="mb-3">
                                        <i class="bi bi-clock-history"></i> Version History (@doc.Versions.Count versions)
                                    </h6>
                                    <table class="table table-sm table-bordered mb-0 dashboard-table version-table">
                                        <thead class="table-secondary">
                                            <tr>
                                                <th>Version</th>
                                                <th>File Name</th>
                                                <th>Size</th>
                                                <th>Created By</th>
                                                <th>Created Date</th>
                                                <th>Comment</th>
                                                <th>Actions</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var version in doc.Versions.OrderByDescending(v => v.Version))
                                            {
                                                var isCurrent = version.Version == doc.CurrentVersion;
                                                <tr class="@(isCurrent ? "table-success" : "")">
                                                    <td>
                                                        <strong>@version.Version</strong>
                                                        @if (isCurrent)
                                                        {
                                                            <span class="badge bg-success ms-2">Current</span>
                                                        }
                                                        @if (version.RestoredFromVersion.HasValue)
                                                        {
                                                            <span class="badge bg-info ms-2" title="Restored from version @version.RestoredFromVersion">
                                                                <i class="bi bi-arrow-counterclockwise"></i> Restored
                                                            </span>
                                                        }
                                                    </td>
                                                    <td>
                                                        <i class="bi bi-file-earmark"></i> @version.FileName
                                                    </td>
                                                    <td>@version.FormattedFileSize</td>
                                                    <td>@version.CreatedBy</td>
                                                    <td>@version.CreatedAtUtc.ToLocalTime().ToString("MM/dd/yyyy HH:mm")</td>
                                                    <td>
                                                        <small class="text-muted">@version.Comment</small>
                                                    </td>
                                                    <td>
                                                        <div class="btn-group btn-group-sm">
                                                            <a href="@Url.Action("Index", "Edit", new { id = doc.DocumentId, version = version.Version })" 
                                                               class="btn btn-outline-primary" 
                                                               title="Edit this version">
                                                                <i class="bi bi-pencil"></i> Edit
                                                            </a>
                                                            @if (!isCurrent)
                                                            {
                                                                <button type="button" 
                                                                        class="btn btn-outline-warning" 
                                                                        onclick="restoreVersion('@doc.DocumentId', @version.Version, @doc.CurrentVersion)"
                                                                        title="Restore this version">
                                                                    <i class="bi bi-arrow-counterclockwise"></i> Restore
                                                                </button>
                                                            }
                                                           <a href="@Url.Action("Download", "Home", new { id = doc.DocumentId, version = version.Version })" 
                                                               class="btn btn-outline-secondary" 
                                                               title="Download this version">
                                                                <i class="bi bi-download"></i> Download
                                                            </a>
                                                        </div>
                                                    </td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        
        <div class="mt-3">
            <p class="text-muted">
                <i class="bi bi-file-earmark-text"></i> 
                @if (Model.IsSearchActive)
                {
                    <span>Search Results: <strong>@Model.DisplayedResults</strong> of <strong>@Model.TotalResults</strong> document(s)</span>
                }
                else
                {
                    <span>Total Documents: <strong>@Model.Documents.Count</strong></span>
                }
            </p>
        </div>
    }
</div>

<form id="restoreForm" method="post" asp-action="RestoreVersion" asp-controller="Home">
    <input type="hidden" name="documentId" id="restoreDocumentId" />
    <input type="hidden" name="versionToRestore" id="restoreVersionNumber" />
    <input type="hidden" name="currentVersion" id="restoreCurrentVersion" />
</form>

<!-- Create New Document Modal -->
<div class="modal fade" id="createDocumentModal" tabindex="-1" aria-labelledby="createDocumentModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <form id="createDocumentForm" method="post" asp-action="CreateNewDocument" asp-controller="Home">
                <div class="modal-header bg-primary text-white">
                    <h5 class="modal-title" id="createDocumentModalLabel">
                        <i class="bi bi-file-earmark-plus"></i> Create New Document
                    </h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label for="documentTitle" class="form-label">
                            Document Title <span class="text-danger">*</span>
                        </label>
                        <input type="text" 
                               class="form-control" 
                               id="documentTitle" 
                               name="title" 
                               placeholder="Enter document title" 
                               required 
                               maxlength="200">
                        <div class="form-text">Give your document a descriptive title.</div>
                    </div>
                    
                    <div class="mb-3">
                        <label for="documentSubject" class="form-label">
                            Subject <span class="text-muted">(Optional)</span>
                        </label>
                        <input type="text" 
                               class="form-control" 
                               id="documentSubject" 
                               name="subject" 
                               placeholder="Enter document subject"
                               maxlength="500">
                        <div class="form-text">Brief description of the document's purpose.</div>
                    </div>
                    
                    <div class="mb-3">
                        <label for="documentTags" class="form-label">
                            Tags <span class="text-muted">(Optional)</span>
                        </label>
                        <input type="text" 
                               class="form-control" 
                               id="documentTags" 
                               name="tags" 
                               placeholder="e.g., contract, legal, draft">
                        <div class="form-text">Comma-separated tags for categorization.</div>
                    </div>

                    <div class="alert alert-info mb-0">
                        <i class="bi bi-info-circle"></i> 
                        A blank document will be created and opened in the editor.
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                        <i class="bi bi-x-circle"></i> Cancel
                    </button>
                    <button type="submit" class="btn btn-primary" id="createDocumentButton">
                        <i class="bi bi-file-earmark-plus"></i> Create & Edit
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Delete Document Modal -->
<div class="modal fade" id="deleteModal" tabindex="-1" aria-labelledby="deleteModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header bg-danger text-white">
                <h5 class="modal-title" id="deleteModalLabel">
                    <i class="bi bi-trash"></i> Delete Document
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div class="alert alert-danger">
                    <i class="bi bi-exclamation-triangle-fill"></i>
                    This will permanently delete <strong id="deleteDocumentTitle"></strong> and all its versions.
                </div>
                <p>Are you sure you want to proceed?</p>
                <input type="hidden" id="deleteDocumentId" />
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                    <i class="bi bi-x-circle"></i> Cancel
                </button>
                <button type="button" class="btn btn-danger" id="confirmDeleteButton" onclick="confirmDeleteDocument()">
                    <i class="bi bi-trash"></i> Delete
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Restore Version Modal -->
<div class="modal fade" id="restoreModal" tabindex="-1" aria-labelledby="restoreModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header bg-warning">
                <h5 class="modal-title" id="restoreModalLabel">
                    <i class="bi bi-arrow-counterclockwise"></i> Restore Version
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div class="alert alert-warning mb-3">
                    <i class="bi bi-exclamation-triangle-fill"></i> 
                    <strong>Important:</strong> This action will create a new version with the content from the selected version.
                </div>
                <p>Are you sure you want to restore <strong>Version <span id="restoreVersionDisplay"></span></strong>?</p>
                <p class="text-muted">
                    <i class="bi bi-info-circle"></i> 
                    This will create a new version with the content from version <span id="restoreVersionDisplay2"></span>. 
                    The current version will remain in the history.
                </p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                    <i class="bi bi-x-circle"></i> Cancel
                </button>
                <button type="button" class="btn btn-warning" id="confirmRestoreButton" onclick="confirmRestore()">
                    <i class="bi bi-arrow-counterclockwise"></i> Restore Version
                </button>
            </div>
        </div>
    </div>
</div>

@section Styles {
    <link rel="stylesheet" href="~/css/home.css" asp-append-version="true" />
}

@section Scripts {
    <script>
        window.homeConfig = {
            searchQuery: '@Html.Raw(Model.SearchQuery ?? "")',
            deleteUrl: '@Url.Action("Delete", "Home")',
            updateStatusUrl: '@Url.Action("UpdateStatus", "Home")'
        };
    </script>
    <script src="~/js/home.js" asp-append-version="true"></script>
}
